<UserControl x:Class="EfmlGen.Wpf.DiagramView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI" FontSize="13">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F0F4F8" Padding="8" Margin="0,0,0,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text=".efml:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" x:Name="EfmlPathBox" Padding="6,3" VerticalContentAlignment="Center"/>
                <Button Grid.Column="2" Content="..." Click="Browse_Click" MinWidth="36" Margin="6,0,0,0"/>
                <Button Grid.Column="3" Content="Load Diagram" Click="Load_Click" Padding="14,5" MinWidth="120" Margin="6,0,0,0"/>
                <TextBlock Grid.Column="4" x:Name="ZoomText" Text="100%" VerticalAlignment="Center" Margin="16,0,8,0" FontWeight="SemiBold" MinWidth="48"/>
                <Button Grid.Column="5" Content="−" Click="ZoomOut_Click" MinWidth="32" Padding="0" Margin="2,0,0,0"/>
                <Button Grid.Column="6" Content="+" Click="ZoomIn_Click" MinWidth="32" Padding="0" Margin="2,0,0,0"/>
                <Button Grid.Column="7" Content="Fit" Click="Fit_Click" MinWidth="56" Margin="6,0,0,0"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" x:Name="DiagramScroll"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      PreviewMouseWheel="DiagramScroll_PreviewMouseWheel"
                      PreviewMouseRightButtonDown="DiagramScroll_PanStart"
                      PreviewMouseRightButtonUp="DiagramScroll_PanEnd"
                      PreviewMouseMove="DiagramScroll_PanMove"
                      Background="#F8F8F8">
            <Canvas x:Name="DiagramCanvas" Width="3000" Height="3000" Background="Transparent">
                <Canvas.LayoutTransform>
                    <ScaleTransform x:Name="ZoomTransform" ScaleX="1" ScaleY="1"/>
                </Canvas.LayoutTransform>
            </Canvas>
        </ScrollViewer>

        <Border Grid.Row="2" Background="#F0F4F8" Padding="8,4">
            <TextBlock x:Name="StatusText" Text="No diagram loaded. Tip: Ctrl+Wheel to zoom; right-click drag to pan." Foreground="#555"/>
        </Border>
    </Grid>
</UserControl>
