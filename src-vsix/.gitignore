bin/
obj/
*.user
*.suo
.vs/

# Bundled CLI publish drop (regenerated by MSBuild target each Release build)
EfmlGen.Vsix/tools/cli/

# Strong-naming key (developer-local, generate with: sn -k Key.snk)
EfmlGen.Vsix/Key.snk

# VSIX build outputs (.vsix files). Negate the EfmlGen.Vsix/ project directory
# whose name unfortunately ends in .vsix and would otherwise be matched.
*.vsix
!EfmlGen.Vsix/
