<Window x:Class="EfmlGen.Vsix.Wizard.AddEfmlModelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add EfmlGen Entity Model"
        Width="500" Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Scaffolds a new .efml from a database using a saved profile."
                   TextWrapping="Wrap" Margin="0,0,0,12" Opacity="0.8"/>

        <TextBlock Grid.Row="1" Text="Connection profile" FontWeight="SemiBold" Margin="0,4,0,2"/>
        <ComboBox Grid.Row="2" x:Name="ProfileCombo" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="3" Text="Model name" FontWeight="SemiBold" Margin="0,4,0,2"/>
        <TextBox Grid.Row="4" x:Name="ModelNameBox" Padding="4,3" Margin="0,0,0,8"/>

        <StackPanel Grid.Row="5">
            <TextBlock Text="Namespace" FontWeight="SemiBold" Margin="0,4,0,2"/>
            <TextBox x:Name="NamespaceBox" Padding="4,3" Margin="0,0,0,8"/>

            <TextBlock Text="Table filter (optional, comma-separated; empty = all)" FontWeight="SemiBold" Margin="0,4,0,2"/>
            <TextBox x:Name="TablesBox" Padding="4,3"/>

            <TextBlock x:Name="NoProfileWarning"
                       Foreground="#B00020"
                       TextWrapping="Wrap"
                       Margin="0,12,0,0"
                       Visibility="Collapsed"
                       Text="No saved profiles found. Open Tools → EfmlGen Tool Window first to create a connection profile."/>
        </StackPanel>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="OkButton" Content="OK" Width="80" IsDefault="True" Click="Ok_Click" Margin="0,0,8,0"/>
            <Button Content="Cancel" Width="80" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
