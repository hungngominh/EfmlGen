<UserControl x:Class="EfmlGen.Vsix.ToolWindow.EfmlGenToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vsui="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"
             Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             d:DesignHeight="700" d:DesignWidth="420">
    <UserControl.Resources>
        <Style TargetType="TextBlock" x:Key="FieldLabel">
            <Setter Property="Margin" Value="0,8,0,2"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="4,3"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="0,0,6,6"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="10">
            <StackPanel>
                <TextBlock Text="Profile" Style="{StaticResource FieldLabel}"/>
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="↻" Width="28" Margin="6,0,0,0"
                            ToolTip="Refresh profiles from profiles.json"
                            Command="{Binding RefreshProfilesCommand}"/>
                    <Button DockPanel.Dock="Right" Content="Save" Margin="6,0,0,0"
                            Command="{Binding SaveProfileCommand}"/>
                    <ComboBox IsEditable="True"
                              ItemsSource="{Binding Profiles}"
                              Text="{Binding SelectedProfileName, UpdateSourceTrigger=PropertyChanged}"/>
                </DockPanel>

                <Separator Margin="0,12"/>
                <TextBlock Text="CONNECTION" FontSize="11" Opacity="0.7"/>

                <TextBlock Text="Provider" Style="{StaticResource FieldLabel}"/>
                <ComboBox ItemsSource="{Binding ProviderOptions}" SelectedItem="{Binding Provider}"/>

                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Host" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Port" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Database" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding Database, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Username" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Password" Style="{StaticResource FieldLabel}"/>
                <PasswordBox x:Name="PasswordBox" Padding="4,3" PasswordChanged="PasswordBox_OnChanged"/>

                <TextBlock Text="Schemas (comma-separated)" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding Schemas, UpdateSourceTrigger=PropertyChanged}"/>

                <Separator Margin="0,12"/>
                <TextBlock Text="OUTPUT" FontSize="11" Opacity="0.7"/>

                <TextBlock Text="Model name" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding ModelName, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Namespace" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding Namespace, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Output directory" Style="{StaticResource FieldLabel}"/>
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="…" Width="28" Margin="6,0,0,0"
                            Click="BrowseOutputDir_Click" ToolTip="Browse folder…"/>
                    <TextBox Text="{Binding OutputDir, UpdateSourceTrigger=PropertyChanged}"/>
                </DockPanel>

                <TextBlock Text="Context class (optional)" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding ContextClass, UpdateSourceTrigger=PropertyChanged}"/>

                <Separator Margin="0,12"/>

                <WrapPanel>
                    <Button Content="Test Connection" Command="{Binding TestConnectionCommand}"/>
                    <Button Content="Scaffold .efml" Command="{Binding ScaffoldCommand}"/>
                    <Button Content="Generate .cs" Command="{Binding GenerateCommand}"/>
                    <Button Content="Sync (both)" Command="{Binding SyncCommand}"
                            FontWeight="Bold"/>
                </WrapPanel>
            </StackPanel>
        </ScrollViewer>

        <GridSplitter Grid.Row="0" Grid.RowSpan="2" Height="4"
                      HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
                      Background="{DynamicResource {x:Static vsshell:VsBrushes.GridLineKey}}"/>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <DockPanel Grid.Row="0" Margin="10,6,10,2">
                <Button DockPanel.Dock="Right" Content="Clear" Command="{Binding ClearLogCommand}" Margin="6,0,0,0"/>
                <TextBlock Text="Log" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </DockPanel>
            <ListBox Grid.Row="1" Margin="10,0,10,10"
                     x:Name="LogList"
                     ItemsSource="{Binding LogLines}"
                     FontFamily="Consolas, Cascadia Mono, monospace"
                     FontSize="11"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     VirtualizingPanel.IsVirtualizing="True">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="2,0"/>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Grid>
    </Grid>
</UserControl>
